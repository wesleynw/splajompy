---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div class="mx-auto my-8 max-w-5xl text-amber-50">
        <h1 class="mb-6 text-3xl font-bold">Terms of Service</h1>

        <p class="mb-6 text-sm text-gray-400">
            <strong>Updated:</strong> June 8, 2025
        </p>

        <section class="mb-6">
            <h2 class="mb-3 text-xl font-semibold">1. Acceptance of Terms</h2>
            <p class="mb-4">
                By accessing or using our platform, you agree to be bound by
                these Terms of Service and our Privacy Policy. If you don't
                agree, please don't use our service. These terms constitute a
                legally binding agreement between you and our company.
            </p>
        </section>

        <section class="mb-6">
            <h2 class="mb-3 text-xl font-semibold">
                2. Eligibility and Age Requirements
            </h2>

            <ul class="mb-4 list-disc pl-6">
                <li>You must be at least 13 years old to use our service</li>
                <li>
                    By creating an account, you represent that you meet these
                    age requirements
                </li>
            </ul>
        </section>

        <section class="mb-6">
            <h2 class="mb-3 text-xl font-semibold">3. User Accounts</h2>

            <ul class="mb-4 list-disc pl-6">
                <li>
                    You're responsible for maintaining account security and
                    keeping credentials confidential
                </li>
                <li>You're liable for all activities under your account</li>
                <li>
                    We may suspend or terminate accounts that violate these
                    terms
                </li>
                <li>
                    One person, one account - multiple accounts may be merged or
                    suspended
                </li>
                <li>
                    Notify us immediately of any unauthorized account access
                </li>
            </ul>
        </section>

        <section class="mb-6">
            <h2 class="mb-3 text-xl font-semibold">12. Contact Information</h2>

            <p class="mb-2">For questions about these terms, contact us at:</p>

            <ul class="mb-4 list-disc pl-6">
                <li>
                    <a href="mailto:wesleynw@pm.me" class="underline">
                        wesleynw [at] pm.me
                    </a>
                </li>
            </ul>
        </section>
    </div>
</Layout>

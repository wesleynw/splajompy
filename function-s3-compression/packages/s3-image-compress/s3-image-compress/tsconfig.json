{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",                    
    "moduleResolution": "NodeNext",         
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist", 
    "rootDir": "src" 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
